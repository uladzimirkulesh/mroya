{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
	"title": "Contrast",
	"settings": {
		"custom": {
			"color": {
				"background": "var:preset|color|base",
				"cursor": "var:preset|color|contrast",
				"sidebar": {
					"background": "var:preset|color|base"
				},
				"base": "#ffffff",
				"contrast": "#0a0a0a",
				"contrast-2": "color-mix(in srgb, #0a0a0a 95%, transparent)",
				"contrast-3": "color-mix(in srgb, #0a0a0a 50%, transparent)",
				"contrast-4": "color-mix(in srgb, #0a0a0a 14%, transparent)",
				"contrast-5": "color-mix(in srgb, #0a0a0a 2%, transparent)"
			}
		},
		"color": {
			"palette": [
				{
					"color": "#0a0a0a",
					"name": "Base",
					"slug": "base"
				},
				{
					"color": "#ffffff",
					"name": "Contrast",
					"slug": "contrast"
				},
				{
					"color": "color-mix(in srgb, #ffffff 75%, transparent)",
					"name": "Contrast / Two",
					"slug": "contrast-2"
				},
				{
					"color": "color-mix(in srgb, #ffffff 40%, transparent)",
					"name": "Contrast / Three",
					"slug": "contrast-3"
				},
				{
					"color": "color-mix(in srgb, #ffffff 15%, transparent)",
					"name": "Contrast / Four",
					"slug": "contrast-4"
				},
				{
					"color": "color-mix(in srgb, #ffffff 3%, transparent)",
					"name": "Contrast / Five",
					"slug": "contrast-5"
				},
				{
					"color": "#f4f4f4",
					"name": "Accent",
					"slug": "accent"
				},
				{
					"color": "#df042d",
					"name": "Danger",
					"slug": "danger"
				}
			]
		}
	},
	"styles": {
		"variations": {
			"section-contrast": {
				"color": {
					"background": "var:preset|color|accent"
				}
			}
		}
	}
}
