{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
	"slug": "section-contrast",
	"title": "Contrast",
	"blockTypes": [
		"core/group",
		"core/columns",
		"core/column"
	],
	"styles": {
		"color": {
			"background": "var:preset|color|contrast",
			"text": "var:preset|color|base"
		},
		"blocks": {
			"core/heading": {
				"color": {
					"text": "currentColor"
				}
			},
			"core/separator": {
				"color": {
					"text": "currentColor",
					"background": "color-mix(in srgb, currentColor 15%, transparent)"
				}
			}
		}
	}
}
