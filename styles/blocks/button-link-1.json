{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
	"title": "Link 1",
	"slug": "link-1",
	"blockTypes": [
		"core/button"
	],
	"styles": {
		"color": {
			"text": "var:preset|color|contrast",
			"background": "transparent"
		},
		"typography": {
			"textDecoration": "underline"
		},
		"border": {
			"width": "0"
		},
		"spacing": {
			"padding": {
				"top": "0",
				"right": "0",
				"bottom": "0",
				"left": "0"
			}
		},
		"elements": {
			"button": {
				":hover": {
					"typography": {
						"textDecoration": "underline"
					}
				},
				":focus": {
					"typography": {
						"textDecoration": "underline dotted"
					}
				},
				":active": {
					"typography": {
						"textDecoration": "underline"
					}
				}
			}
		}
	}
}
