{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
	"title": "Outline",
	"slug": "outline",
	"blockTypes": [
		"core/button"
	],
	"styles": {
		"color": {
			"text": "var:preset|color|contrast",
			"background": "transparent"
		},
		"border": {
			"width": "2px",
			"style": "solid",
			"color": "var:preset|color|contrast"
		},
		"spacing": {
			"padding": {
				"top": "0.5rem",
				"right": "1.125rem",
				"bottom": "0.5rem",
				"left": "1.125rem"
			}
		}
	}
}
